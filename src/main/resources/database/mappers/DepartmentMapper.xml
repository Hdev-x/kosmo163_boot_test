<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!-- FQDN 사용할 DAO의 클래스명을 풀패키지명으로 작성 -->
<mapper namespace="com.semin.app.departments.DepartmentDAO">
	<!--쿼리 태그 -->
	<!-- 컬럼명과 resultType의 Bean의 Setter이름이 같은걸 찾아서 대입 -->
	<select id="list"
		resultType="com.semin.app.departments.DepartmentDTO">
		SELECT * FROM TB_DEPARTMENT
	</select>

	<select id="detail" parameterType="java.lang.String"
		resultType="com.semin.app.departments.DepartmentDTO">
		SELECT * FROM TB_DEPARTMENT
		WHERE DEPARTMENT_NO = #{num}
	</select>
</mapper>